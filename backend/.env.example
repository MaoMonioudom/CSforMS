# Frontend base URL — used to build redirect links for the Microsoft OAuth flow
FRONTEND_URL=your_frontend_url

MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret_key
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_REDIRECT_URI=http_callback
MICROSOFT_ALLOWED_EMAIL_DOMAIN=your_email_format