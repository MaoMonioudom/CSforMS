# Port the Express server listens on. Falls back to 4000 if unset.
PORT=4000

# Supabase project credentials (Settings → API in the Supabase dashboard).
# SERVICE_ROLE_KEY bypasses RLS — this app has no RLS policies on its own
# tables, so this key is used for nearly every query. Keep it server-side
# only, never expose it to the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of allowed frontend origins for CORS, e.g.
# http://localhost:5173,https://your-deployed-frontend.example.
# Leave empty/unset to allow all origins (fine for local dev).
CORS_ORIGIN=http://localhost:5173

# Signs/verifies the app's own auth JWTs (this app uses bcrypt + JWT against
# the `users` table, not Supabase Auth). Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret
# Any `ms` package duration string. Falls back to 7d if unset.
JWT_EXPIRES_IN=7d

# Base URL of the deployed frontend — used to build the redirect links the
# Microsoft OAuth flow sends the browser back to after login.
FRONTEND_URL=http://localhost:5173

# Microsoft Entra ID (Azure AD) app registration, for "Continue with
# Microsoft" login. Falls back to the "common" (multi-tenant) endpoint if
# MICROSOFT_TENANT_ID is unset.
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
# Must exactly match a redirect URI configured on the Azure app registration.
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
# Comma-separated email domains allowed to sign up via Microsoft (subdomains
# count, e.g. "cadt.edu.kh" also admits "student.cadt.edu.kh"). Leave
# empty/unset to allow any domain.
MICROSOFT_ALLOWED_EMAIL_DOMAIN=cadt.edu.kh
